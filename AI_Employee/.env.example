# AI Employee — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Anthropic ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Gmail ─────────────────────────────────────────────────────────────────
# Used by: gmail_watcher.py, mcp_server.py (send_email), action.py
GMAIL_USER=you@gmail.com
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx   # Generate at: myaccount.google.com/apppasswords
GMAIL_POLL_INTERVAL=60                   # Seconds between inbox checks

# ── LinkedIn ──────────────────────────────────────────────────────────────
# Used by: linkedin_watcher.py, mcp_server.py (post_to_linkedin), action.py
#
# Get access token via LinkedIn OAuth2 (3-legged):
#   https://www.linkedin.com/developers/apps → your app → Auth tab
# Required scopes: w_member_social, r_liteprofile, r_emailaddress
#
# Get your person URN:
#   curl -H "Authorization: Bearer <token>" https://api.linkedin.com/v2/me
#   Look for "id" field, then format as: urn:li:person:<id>
LINKEDIN_ACCESS_TOKEN=your_linkedin_access_token_here
LINKEDIN_PERSON_URN=urn:li:person:XXXXXXXXX
LINKEDIN_POLL_INTERVAL=300               # Seconds between notification polls

# ── Scheduler ─────────────────────────────────────────────────────────────
SCHEDULER_GMAIL_INTERVAL_MINUTES=60
SCHEDULER_TASKS_INTERVAL_MINUTES=5
SCHEDULER_LINKEDIN_DAY=monday            # monday/tuesday/wednesday/thursday/friday
SCHEDULER_LINKEDIN_TIME=09:00            # 24-hour format HH:MM
